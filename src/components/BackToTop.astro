<div
  id="back-to-top"
  class="fixed bottom-6 right-6 z-50 flex translate-y-4 flex-col items-center gap-2 opacity-0 pointer-events-none transition-all duration-300 ease-out"
>
  <span
    class="animate-float rounded-full bg-base-200 px-3 py-1 text-xs font-medium text-base-content shadow-md ring-1 ring-primary/30"
  >
    Vissza a tetejére
  </span>
  <button
    id="back-to-top-btn"
    aria-label="Vissza a tetejére"
    class="btn btn-primary btn-circle shadow-lg transition-transform duration-300 hover:-translate-y-1"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-5 w-5"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2.2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"></path>
    </svg>
  </button>
</div>

<script>
  const wrap = document.getElementById("back-to-top");
  const btn = document.getElementById("back-to-top-btn");

  const toggle = () => {
    if (!wrap) return;
    const show = window.scrollY > 400;
    wrap.classList.toggle("opacity-0", !show);
    wrap.classList.toggle("translate-y-4", !show);
    wrap.classList.toggle("pointer-events-none", !show);
    wrap.classList.toggle("opacity-100", show);
  };

  toggle();
  window.addEventListener("scroll", toggle, { passive: true });

  btn?.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>

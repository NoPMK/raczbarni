---
import { site } from "../data/site";
import SectionDivider from "./SectionDivider.astro";
---

<section id="szolgaltatasok" class="bg-base-100 py-24">
  <div class="section-shell">
    <div class="mx-auto max-w-2xl text-center">
      <SectionDivider label="Szolgáltatások" />
      <h2 class="mt-4 text-4xl font-semibold sm:text-5xl" data-aos="fade-up">
        Mire számíthatsz?
      </h2>
      <p class="mt-4 text-base-content/70" data-aos="fade-up" data-aos-delay="80">
        Két fókuszterület, tiszta kerettel — nézd meg egy pillantással, miben és
        hogyan tudunk együtt dolgozni.
      </p>
    </div>

    <div class="mt-14 flex flex-col gap-8">
      {
        site.services.map((service, i) => (
          <article
            class="surface overflow-hidden rounded-box shadow-md"
            data-aos="fade-up"
            data-aos-delay={i * 100}
          >
            <div class="grid gap-8 p-8 sm:p-10 lg:grid-cols-2 lg:gap-12">
              {/* Left: identity + intro + examples */}
              <div>
                <div class="flex items-center gap-4">
                  <div class="flex h-14 w-14 flex-none items-center justify-center rounded-2xl bg-[#1b5e20]/10 text-[#1b5e20]">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-7 w-7"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.8"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d={service.icon}
                      />
                    </svg>
                  </div>
                  <div>
                    <h3 class="surface-heading font-display text-3xl font-semibold">
                      {service.title}
                    </h3>
                    <p class="ink-green text-sm font-medium">
                      {service.tagline}
                    </p>
                  </div>
                </div>

                <p class="surface-body mt-5 text-[0.95rem] leading-relaxed">
                  {service.details.intro}
                </p>

                <p class="surface-heading mt-6 text-xs font-semibold uppercase tracking-[0.18em]">
                  Példák, amikben segítek
                </p>
                <ul class="mt-3 grid gap-2.5 sm:grid-cols-2">
                  {service.bullets.map((b) => (
                    <li class="surface-body flex items-start gap-2.5 text-sm">
                      <svg
                        class="mt-0.5 h-4 w-4 flex-none text-[#1b5e20]"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                      >
                        <path
                          fill-rule="evenodd"
                          d="M16.7 5.3a1 1 0 010 1.4l-7.5 7.5a1 1 0 01-1.4 0L3.3 9.7a1 1 0 011.4-1.4l3.1 3.1 6.8-6.8a1 1 0 011.4 0z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      {b}
                    </li>
                  ))}
                </ul>
              </div>

              {/* Right: more information */}
              <div class="flex flex-col justify-center gap-5 rounded-box bg-black/[0.03] p-6 sm:p-7">
                {service.details.sections.map((s) => (
                  <div>
                    <h4 class="surface-heading text-sm font-semibold">
                      {s.heading}
                    </h4>
                    <p class="surface-body mt-1 text-sm leading-relaxed">
                      {s.body}
                    </p>
                  </div>
                ))}
              </div>
            </div>

            {/* Pricing strip (de-emphasized) + CTA */}
            <div class="flex flex-col gap-4 border-t border-black/10 bg-black/[0.02] px-8 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-10">
              <div class="flex flex-wrap items-center gap-2">
                {service.pricing.type === "fixed" ? (
                  <span class="inline-flex items-baseline gap-1.5 rounded-full bg-[#1b5e20]/10 px-4 py-1.5 text-sm ink-green">
                    <span class="font-bold">{service.pricing.price}</span>
                    {service.pricing.unit && <span>{service.pricing.unit}</span>}
                    {service.pricing.note && (
                      <span class="opacity-70">· {service.pricing.note}</span>
                    )}
                  </span>
                ) : (
                  service.pricing.items.map((item) => (
                    <span class="inline-flex items-baseline gap-1.5 rounded-full bg-[#1b5e20]/10 px-4 py-1.5 text-sm ink-green">
                      <span>{item.name}</span>
                      <span class="font-bold">{item.price}</span>
                    </span>
                  ))
                )}
              </div>
              <a
                href={site.cta.href}
                class="btn btn-primary btn-sm shrink-0 rounded-btn px-5"
              >
                {site.cta.label}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

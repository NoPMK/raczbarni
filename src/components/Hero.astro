---
import { site } from "../data/site";
---

<section id="top" class="relative isolate overflow-hidden">
  <!-- Background image + warm green overlay -->
  <div class="absolute inset-0 -z-10">
    <img
      src={site.heroImage}
      alt=""
      class="h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-base-100/75 via-base-100/80 to-base-100"
    >
    </div>
  </div>

  <div class="section-shell flex min-h-screen flex-col justify-center pt-28 pb-20 text-white">
    <!-- Intro -->
    <div class="max-w-3xl">
      <p
        class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-white/80"
        data-aos="fade-up"
      >
        Coaching & teljesítmény
      </p>
      <h1
        class="text-balance text-5xl font-semibold leading-[1.05] sm:text-6xl lg:text-7xl"
        data-aos="fade-up"
        data-aos-delay="80"
      >
        {site.name}
      </h1>

      <div
        class="mt-6 flex flex-wrap gap-2.5"
        data-aos="fade-up"
        data-aos-delay="160"
      >
        {site.heroTags.map((tag) => <span class="pill">{tag}</span>)}
      </div>

      <div
        class="mt-9 flex flex-wrap items-center gap-4"
        data-aos="fade-up"
        data-aos-delay="240"
      >
        <a href={site.cta.href} class="btn btn-secondary btn-lg rounded-btn text-white">
          {site.cta.label}
        </a>
        <a
          href="#szolgaltatasok"
          class="btn btn-ghost btn-lg rounded-btn text-white hover:bg-white/15"
        >
          Szolgáltatások
        </a>
      </div>
    </div>

    <!-- About cards (merged into hero) -->
    <div
      id="rolam"
      class="mt-16 grid gap-6 lg:mt-24 lg:grid-cols-5"
      data-aos="fade-up"
      data-aos-delay="120"
    >
      <!-- Portrait card -->
      <figure
        class="lift-card group relative col-span-2 overflow-hidden rounded-box shadow-xl"
      >
        <img
          src={site.portrait}
          alt={site.name}
          class="aspect-[4/5] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
          loading="lazy"
        />
        <figcaption
          class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/60 to-transparent p-5 text-white"
        >
          <span class="font-display text-lg">{site.name}</span>
          <span class="block text-sm text-white/80">{site.role}</span>
        </figcaption>
      </figure>

      <!-- Expanding bio card -->
      <article
        class="surface lift-card col-span-3 flex flex-col rounded-box p-7 shadow-xl sm:p-9"
      >
        <h2 class="surface-heading text-2xl font-semibold sm:text-3xl">
          {site.about.heading}
        </h2>
        <p class="surface-body mt-4">{site.about.shortBio}</p>

        <div
          id="bio-extra"
          class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-in-out"
        >
          <div class="overflow-hidden">
            <div class="surface-body space-y-3 pt-4">
              {site.about.longBio.map((p) => <p>{p}</p>)}
            </div>
          </div>
        </div>

        <button
          id="bio-toggle"
          class="btn btn-link ink-green mt-4 w-fit gap-1 px-0 no-underline hover:no-underline"
          aria-expanded="false"
          aria-controls="bio-extra"
        >
          <span data-label>Olvass tovább</span>
          <svg
            class="h-4 w-4 transition-transform duration-300"
            data-chevron
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
      </article>
    </div>
  </div>
</section>

<script>
  const toggle = document.getElementById("bio-toggle");
  const extra = document.getElementById("bio-extra");
  const label = toggle?.querySelector("[data-label]");
  const chevron = toggle?.querySelector("[data-chevron]");

  toggle?.addEventListener("click", () => {
    const expanded = extra?.classList.toggle("grid-rows-[1fr]") ?? false;
    extra?.classList.toggle("grid-rows-[0fr]", !expanded);
    toggle.setAttribute("aria-expanded", String(expanded));
    if (label) label.textContent = expanded ? "Mutass kevesebbet" : "Olvass tovább";
    chevron?.classList.toggle("rotate-180", expanded);
  });
</script>

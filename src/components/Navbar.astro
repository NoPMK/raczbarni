---
import { site } from "../data/site";
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  data-state="top"
>
  <nav class="section-shell flex h-20 items-center justify-between">
    <a
      href="#top"
      class="font-display text-lg font-semibold tracking-tight text-primary transition-colors"
      data-brand
    >
      {site.name}
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        site.nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="relative text-sm font-medium opacity-90 transition-all duration-300 hover:opacity-100 hover:text-primary after:absolute after:-bottom-1.5 after:left-0 after:h-0.5 after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full"
              data-link
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href={site.cta.href} class="btn btn-primary btn-sm rounded-btn">
          {site.cta.label}
        </a>
      </li>
    </ul>

    <button
      id="nav-toggle"
      class="md:hidden"
      aria-label="Menü"
      aria-expanded="false"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-7 w-7"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-base-300 bg-base-100/95 backdrop-blur md:hidden"
  >
    <ul class="section-shell flex flex-col gap-1 py-4">
      {
        site.nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="block rounded-btn px-3 py-2 text-base-content hover:bg-base-200"
              data-mobile-link
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a href={site.cta.href} class="btn btn-primary w-full" data-mobile-link>
          {site.cta.label}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const nav = document.getElementById("site-nav");
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");

  // Solidify navbar after scrolling past the hero top area
  const onScroll = () => {
    if (!nav) return;
    const scrolled = window.scrollY > 40;
    nav.dataset.state = scrolled ? "scrolled" : "top";
    nav.classList.toggle("bg-base-100/90", scrolled);
    nav.classList.toggle("backdrop-blur", scrolled);
    nav.classList.toggle("shadow-sm", scrolled);
    nav.classList.toggle("text-base-content", scrolled);
    nav.classList.toggle("text-white", !scrolled);
  };

  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });

  document.querySelectorAll("[data-mobile-link]").forEach((link) => {
    link.addEventListener("click", () => menu?.classList.add("hidden"));
  });
</script>
